generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String   @id @default(cuid())
  name               String
  email              String   @unique
  password           String
  phone              String?
  age                Int?
  gender             String?
  lookingFor         String?
  bio                String?
  country            String?
  profilePhoto       String?
  tier               String   @default("basic")
  verified           Boolean  @default(false)
  verificationStatus String   @default("none")
  verificationPhoto  String?
  idDocument         String?
  securityQuestion   String?
  securityAnswer     String?
  isPrivate          Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model Message {
  id         String   @id @default(cuid())
  senderId   String
  receiverId String
  content    String
  read       Boolean  @default(false)
  createdAt  DateTime @default(now())
}

model Post {
  id        String   @id @default(cuid())
  userId    String
  content   String?
  image     String?
  createdAt DateTime @default(now())
}

model PostLike {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  emoji     String   @default("heart")
  createdAt DateTime @default(now())

  @@unique([postId, userId])
}

model PostComment {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  content   String
  createdAt DateTime @default(now())
}

model Block {
  id        String   @id @default(cuid())
  blockerId String
  blockedId String
  createdAt DateTime @default(now())

  @@unique([blockerId, blockedId])
}

model ProfileView {
  id        String   @id @default(cuid())
  viewerId  String
  viewedId  String
  createdAt DateTime @default(now())
}

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url       = env("DATABASE_URL")
}

model User {
  id                 String   @id @default(cuid())
  name               String
  email              String   @unique
  username           String?  @unique
  password           String
  phone              String?
  age                Int?
  gender             String?
  lookingFor         String?
  bio                String?
  country            String?
  profilePhoto       String?
  tier               String   @default("basic")
  verified           Boolean  @default(false)
  verificationStatus String   @default("none")
  verificationPhoto  String?
  idDocument         String?
  securityQuestion   String?
  securityAnswer     String?
  resetCode          String?
  resetCodeExpires   DateTime?
  lastActive         DateTime?
  isPrivate          Boolean  @default(false)
  banned             Boolean   @default(false)
  role               String    @default("user")
  adminLastLogin     DateTime?
  adminLastLoginIp   String?
  city               String?
  detectedCity       String?
  detectedCountry    String?
  latitude           Float?
  longitude          Float?
  idDocumentBack     String?
  idType             String?
  photos             String[]  @default([])
  coins              Int      @default(0)
  emailVerified      Boolean  @default(false)
  emailOtp           String?
  emailOtpExpiry     DateTime?
  phoneVerified      Boolean  @default(false)
  phoneOtp           String?
  phoneOtpExpiry     DateTime?
  boostedUntil       DateTime?
  lastLoginReward    DateTime?
  referralCode       String?
  referredBy         String?
  interests          String[]  @default([])
  prompts            String?
  loginStreak        Int       @default(0)
  vibeStatus         String?
  voiceIntro         String?
  lastSeen           DateTime @default(now())
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  hideDob            Boolean  @default(false)
  hideEmail          Boolean  @default(false)
  hidePhone          Boolean  @default(false)
  hideOnline         Boolean  @default(false)
  hideLastSeen       Boolean  @default(false)
  showDistance        Boolean  @default(true)
  allowMessages      String   @default("everyone")
  emailNotifs        Boolean  @default(true)
  pushNotifs         Boolean  @default(true)
  notifMatches       Boolean  @default(true)
  notifMessages      Boolean  @default(true)
  notifLikes         Boolean  @default(true)
  notifGifts         Boolean  @default(true)
  verificationFrames String?
}

model Message {
  id         String   @id @default(cuid())
  senderId   String
  receiverId String
  content    String
  read       Boolean  @default(false)
  readAt     DateTime?
  createdAt  DateTime @default(now())
}

model Post {
  id        String   @id @default(cuid())
  userId    String
  content   String?
  image     String?
  createdAt DateTime @default(now())
}

model PostLike {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  emoji     String   @default("heart")
  createdAt DateTime @default(now())
  @@unique([postId, userId])
}

model PostComment {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  content   String
  createdAt DateTime @default(now())
}

model Block {
  id        String   @id @default(cuid())
  blockerId String
  blockedId String
  createdAt DateTime @default(now())
  @@unique([blockerId, blockedId])
}

model ProfileView {
  id        String   @id @default(cuid())
  viewerId  String
  viewedId  String
  createdAt DateTime @default(now())
}

model Friend {
  id        String   @id @default(cuid())
  userId    String
  friendId  String
  status    String   @default("pending")
  createdAt DateTime @default(now())
  @@unique([userId, friendId])
}


model Call {
  id         String   @id @default(cuid())
  callerId   String
  receiverId String
  type       String   @default("voice")
  status     String   @default("missed")
  duration   Int      @default(0)
  createdAt  DateTime @default(now())
}

model LiveStream {
  id          String    @id @default(cuid())
  userId      String
  title       String?
  category    String    @default("chat")
  isLive      Boolean   @default(true)
  viewerCount Int       @default(0)
  createdAt   DateTime  @default(now())
  endedAt     DateTime?
}

model LiveChat {
  id        String   @id @default(cuid())
  streamId  String
  userId    String
  content   String
  createdAt DateTime @default(now())
}

model Notification {
  id         String   @id @default(cuid())
  userId     String
  type       String
  title      String
  message    String
  fromUserId String?
  read       Boolean  @default(false)
  createdAt  DateTime @default(now())
}

model Gift {
  id         String   @id @default(cuid())
  senderId   String
  receiverId String
  streamId   String?
  giftType   String
  giftName   String
  coinValue  Int
  createdAt  DateTime @default(now())
}

model CoinTransaction {
  id          String   @id @default(cuid())
  userId      String
  amount      Int
  type        String
  description String
  createdAt   DateTime @default(now())
}

model Story {
  id        String   @id @default(cuid())
  userId    String
  image     String
  caption   String?
  viewCount Int      @default(0)
  createdAt DateTime @default(now())
  expiresAt DateTime
}

model StoryView {
  id        String   @id @default(cuid())
  storyId   String
  viewerId  String
  createdAt DateTime @default(now())
  @@unique([storyId, viewerId])
}

model Report {
  id         String   @id @default(cuid())
  reporterId String
  reportedId String
  reason     String
  details    String?
  status     String   @default("pending")
  createdAt  DateTime @default(now())
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
}

model Like {
  id          String   @id @default(cuid())
  fromUserId  String
  toUserId    String
  type        String   @default("like")
  createdAt   DateTime @default(now())

  @@unique([fromUserId, toUserId])
}

model Reaction {
  id        String   @id @default(cuid())
  messageId String
  userId    String
  emoji     String
  createdAt DateTime @default(now())

  @@unique([messageId, userId, emoji])
}

model Withdrawal {
  id          String   @id @default(cuid())
  userId      String
  amount      Int
  method      String   @default("bank")
  details     String?
  status      String   @default("pending")
  adminNote   String?
  createdAt   DateTime @default(now())
  processedAt DateTime?
}

model LiveViewer {
  id        String   @id @default(cuid())
  streamId  String
  userId    String
  lastPing  DateTime @default(now())
  createdAt DateTime @default(now())

  @@unique([streamId, userId])
}


model AdminLog {
  id         String   @id @default(cuid())
  adminId    String
  adminEmail String
  action     String
  targetId   String?
  targetType String?
  details    String?
  ip         String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([adminId])
  @@index([createdAt])
  @@index([action])
}

model AdminLoginAttempt {
  id        String   @id @default(cuid())
  email     String
  ip        String
  success   Boolean
  userAgent String?
  createdAt DateTime @default(now())

  @@index([email, createdAt])
  @@index([ip, createdAt])
}


model QotdAnswer {
  id            String   @id @default(cuid())
  userId        String
  date          String
  questionIndex Int
  answer        String
  createdAt     DateTime @default(now())

  @@unique([userId, date])
}


model Whisper {
  id         String   @id @default(cuid())
  fromUserId String
  toUserId   String
  message    String
  liked      Boolean  @default(false)
  revealed   Boolean  @default(false)
  createdAt  DateTime @default(now())
}
